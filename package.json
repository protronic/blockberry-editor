{
  "name": "@protronic/blockberry-editor",
  "version": "1.0.0",
  "description": "Blockly backend that generates Berry scripts for small IoT control and escalation systems",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./toolbox": "./dist/toolbox.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bun run build:lib && bun run build:web",
    "build:lib": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "preview": "vite preview",
    "test": "bun test",
    "check": "bun run build && bun run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/protronic/blockberry-editor.git"
  },
  "keywords": [
    "blockly",
    "berry",
    "tasmota",
    "canopen",
    "lvgl",
    "plc"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/protronic/blockberry-editor/issues"
  },
  "homepage": "https://github.com/protronic/blockberry-editor#readme",
  "dependencies": {
    "blockly": "^13.1.1"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
